{
  "cleanUrls": true,
    "redirects": [
    {
      "source": "/:path*.html",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/website/index.html" },

    { "source": "/forum", "destination": "/website/forum.html" },
    { "source": "/guides", "destination": "/website/guides.html" },
    { "source": "/profile", "destination": "/website/profile.html" },
    { "source": "/purchases", "destination": "/website/purchases.html" },
    { "source": "/register", "destination": "/website/register.html" },
    { "source": "/reviews", "destination": "/website/reviews.html" },
    { "source": "/settings", "destination": "/website/settings.html" },
    { "source": "/status", "destination": "/website/status.html" },
    { "source": "/support", "destination": "/website/support.html" },
    { "source": "/privacy-policy", "destination": "/website/privacy-policy.html" },
    { "source": "/terms-of-service", "destination": "/website/terms-of-service.html" },
    { "source": "/topic", "destination": "/website/topic.html" },

    { "source": "/products/rust", "destination": "/website/products/rust.html" },
    { "source": "/products/r6s", "destination": "/website/products/r6s.html" },
    { "source": "/products/arc-raiders", "destination": "/website/products/arc-raiders.html" },
    { "source": "/products/hwid-unban", "destination": "/website/products/hwid-unban.html" },

    { "source": "/code-theme/:path*", "destination": "/website/code-theme/:path*" },
    { "source": "/products/:path*", "destination": "/website/products/:path*" },
    { "source": "/images/:path*", "destination": "/website/images/:path*" },

    { "source": "/cart.js", "destination": "/website/cart.js" },
    { "source": "/supabase-auth.js", "destination": "/website/supabase-auth.js" },
    { "source": "/purchases-client.js", "destination": "/website/purchases-client.js" },

    { "source": "/:file", "destination": "/website/:file" }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },

    { "source": "/forum.html", "destination": "/forum", "permanent": true },
    { "source": "/guides.html", "destination": "/guides", "permanent": true },
    { "source": "/profile.html", "destination": "/profile", "permanent": true },
    { "source": "/purchases.html", "destination": "/purchases", "permanent": true },
    { "source": "/register.html", "destination": "/register", "permanent": true },
    { "source": "/reviews.html", "destination": "/reviews", "permanent": true },
    { "source": "/settings.html", "destination": "/settings", "permanent": true },
    { "source": "/status.html", "destination": "/status", "permanent": true },
    { "source": "/support.html", "destination": "/support", "permanent": true },
    { "source": "/privacy-policy.html", "destination": "/privacy-policy", "permanent": true },
    { "source": "/terms-of-service.html", "destination": "/terms-of-service", "permanent": true },
    { "source": "/topic.html", "destination": "/topic", "permanent": true },

    { "source": "/products/rust.html", "destination": "/products/rust", "permanent": true },
    { "source": "/products/r6s.html", "destination": "/products/r6s", "permanent": true },
    { "source": "/products/arc-raiders.html", "destination": "/products/arc-raiders", "permanent": true },
    { "source": "/products/hwid-unban.html", "destination": "/products/hwid-unban", "permanent": true }
  ]
}
